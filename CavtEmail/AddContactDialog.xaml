<Window x:Class="CavtEmail.AddContactDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CavtEmail"
        Title="Save to contacts"
        Background="{StaticResource AppBg}"
        SizeToContent="Height" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Padding="18">
        <StackPanel>
            <TextBlock FontWeight="SemiBold" FontSize="14" Text="Not found in Outlook"/>
            <TextBlock Style="{StaticResource Hint}" Margin="0,4,0,12"
                       Text="This address is syntactically valid but wasn't found in your Outlook address book. You can save it to your local contact cache so future lookups remember it."/>

            <TextBlock Text="Email" Style="{StaticResource Label}"/>
            <TextBox x:Name="EmailBox" IsReadOnly="True" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="First name" Style="{StaticResource Label}"/>
                    <TextBox x:Name="FirstBox" local:TextBoxHelper.Placeholder="(optional)"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Last name" Style="{StaticResource Label}"/>
                    <TextBox x:Name="LastBox" local:TextBoxHelper.Placeholder="(optional)"/>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" Content="Not now" Style="{StaticResource SubtleButton}"
                        Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click"/>
                <Button x:Name="SaveBtn" Content="Save to contacts" Style="{StaticResource PrimaryButton}"
                        IsDefault="True" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
