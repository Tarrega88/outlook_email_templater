<Window x:Class="CavtEmail.ContactsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CavtEmail"
        xmlns:m="clr-namespace:CavtEmail.Models"
        Title="Contacts" Height="520" Width="620"
        Background="{StaticResource AppBg}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top" Text="Contacts" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hint}" Margin="0,0,0,10"
                   Text="These are reusable people. They auto-populate when picking a recipient. New pairs are saved here automatically on send."/>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" local:TextBoxHelper.Placeholder="Search by name or email…"
                     TextChanged="SearchBox_TextChanged"/>
            <Button Grid.Column="1" Content="+ Add" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                    Click="Add_Click"/>
        </Grid>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Close" Style="{StaticResource PrimaryButton}" MinWidth="80"
                    Click="Close_Click"/>
        </StackPanel>

        <ListBox x:Name="ContactList" ItemsSource="{Binding}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type m:Contact}">
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 local:TextBoxHelper.Placeholder="Name"/>
                        <TextBox Grid.Column="1" Margin="6,0"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 local:TextBoxHelper.Placeholder="name@example.com"/>
                        <Button Grid.Column="2" Content="✕" Style="{StaticResource IconButton}"
                                Click="Remove_Click"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
