<Window x:Class="Envoy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Envoy"
        xmlns:vm="clr-namespace:Envoy.ViewModels"
        xmlns:m="clr-namespace:Envoy.Models"
        Title="Envoy — File-to-Person Sender" Height="780" Width="1240"
        Background="{StaticResource AppBg}"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Right-click menu shared by Subject & Body for inserting tokens at the caret. -->
        <ContextMenu x:Key="TokenContextMenu" x:Shared="False">
            <MenuItem Header="Insert recipient">
                <MenuItem Header="{}{{recipients}}"      Tag="{}{{recipients}}"      Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{recipientEmails}}" Tag="{}{{recipientEmails}}" Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{recipientCount}}"  Tag="{}{{recipientCount}}"  Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{greetRecipients}}" Tag="{}{{greetRecipients}}" Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{cc}}"              Tag="{}{{cc}}"              Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{ccEmails}}"        Tag="{}{{ccEmails}}"        Click="TokenMenu_Click"/>
            </MenuItem>
            <MenuItem Header="Insert files">
                <MenuItem Header="{}{{files}}"     Tag="{}{{files}}"     Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{fileList}}"  Tag="{}{{fileList}}"  Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{fileCount}}" Tag="{}{{fileCount}}" Click="TokenMenu_Click"/>
            </MenuItem>
            <MenuItem Header="Insert context">
                <MenuItem Header="{}{{sender}}" Tag="{}{{sender}}" Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{email}}"  Tag="{}{{email}}"  Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{date}}"   Tag="{}{{date}}"   Click="TokenMenu_Click"/>
                <MenuItem Header="{}{{time}}"   Tag="{}{{time}}"   Click="TokenMenu_Click"/>
            </MenuItem>
        </ContextMenu>
    </Window.Resources>

    <DockPanel>

        <!-- ======================== Menu bar ======================== -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open…"    Command="{Binding OpenCommand}"/>
                <MenuItem Header="_Save"     Command="{Binding SaveCommand}"/>
                <MenuItem Header="Save _As…" Command="{Binding SaveAsCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitMenu_Click"/>
            </MenuItem>
            <MenuItem Header="_Contacts">
                <MenuItem Header="_Re-verify with Outlook"   Command="{Binding ReVerifyContactsCommand}"
                          ToolTip="Re-check every saved contact against the Outlook address book and update their verified status."/>
                <Separator/>
                <MenuItem Header="_Clear all contacts…"      Command="{Binding ClearContactsCommand}"
                          ToolTip="Permanently delete every saved contact from local storage."/>
            </MenuItem>
        </Menu>

        <!-- ======================== Top toolbar ======================== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Envoy" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Outlook availability indicator: no COM launch; just reflects whether OUTLOOK.EXE is running. -->
                    <Border Margin="0,0,14,0" Padding="8,3" CornerRadius="10" VerticalAlignment="Center"
                            ToolTip="Resolving names requires classic Outlook to be running.">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#33EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutlookAvailable}" Value="True">
                                        <Setter Property="Background" Value="#3322C55E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock VerticalAlignment="Center" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="● Outlook offline"/>
                                    <Setter Property="Foreground" Value="#FFEF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOutlookAvailable}" Value="True">
                                            <Setter Property="Text" Value="● Outlook"/>
                                            <Setter Property="Foreground" Value="#FF22C55E"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <TextBlock Text="Sender" Style="{StaticResource Label}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBox Width="180" Text="{Binding Config.SenderName, UpdateSourceTrigger=PropertyChanged}"
                             local:TextBoxHelper.Placeholder="Your name"
                             Margin="0,0,14,0"/>

                    <TextBlock Text="Send mode" Style="{StaticResource Label}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <ComboBox Width="160" ItemsSource="{Binding SendModes}"
                              SelectedItem="{Binding Config.SendMode}" Margin="0,0,14,0"/>

                    <CheckBox Content="HTML body" IsChecked="{Binding Config.HtmlBody}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ======================== Status bar ======================== -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="0,1,0,0" Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding CurrentConfigPath}"
                           Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ======================== Main 3-column layout ======================== -->
        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- ========== Left: Emails ========== -->
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Emails" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ Add" Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddEmailCommand}"/>
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Duplicate" Style="{StaticResource SubtleButton}" Margin="0,0,6,0"
                                Command="{Binding DuplicateEmailCommand}"/>
                        <Button Content="Remove" Style="{StaticResource SubtleButton}"
                                Command="{Binding RemoveEmailCommand}"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Emails}" SelectedItem="{Binding SelectedEmail}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,3">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding FilledRecipientCount, StringFormat={}{0} ppl}"
                                                   FontSize="11" Foreground="{StaticResource Muted}" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Attachments.Count, StringFormat={}{0} files}"
                                                   FontSize="11" Foreground="{StaticResource Muted}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ========== Center: Email editor ========== -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,8,0">
                <Grid>
                    <TextBlock Text="Select or create an email on the left."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource Muted}" FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}"
                          DataContext="{Binding SelectedEmail}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- name + send mode -->
                            <RowDefinition Height="Auto"/>   <!-- three columns -->
                            <RowDefinition Height="Auto"/>   <!-- subject -->
                            <RowDefinition Height="*"/>      <!-- body -->
                            <RowDefinition Height="Auto"/>   <!-- footer buttons -->
                        </Grid.RowDefinitions>

                        <!-- Email name -->
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Email name" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="15" FontWeight="SemiBold"
                                     local:TextBoxHelper.Placeholder="e.g. Weekly reports for the AV team"/>
                        </StackPanel>

                        <!-- Recipients / Attachments -->
                        <Grid Grid.Row="1" Margin="0,0,0,12" Height="240">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ===== Recipients ===== -->
                            <Border Style="{StaticResource InnerCard}" Margin="0,0,4,0">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Recipients" Style="{StaticResource SectionTitle}"/>
                                        <Button Grid.Column="1" Content="+ Add" Style="{StaticResource IconButton}"
                                                Command="{Binding DataContext.AddRecipientCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </Grid>
                                    <TextBlock DockPanel.Dock="Bottom" Margin="0,6,0,0" Style="{StaticResource Hint}"
                                               Text="Type a name, alias, or email. Press Tab or Enter to resolve via Outlook. Drop CC to move a row to Cc."/>

                                    <ListBox ItemsSource="{Binding Recipients}"
                                             HorizontalContentAlignment="Stretch">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ToggleButton Style="{StaticResource CcToggle}"
                                                                  IsChecked="{Binding IsCc, UpdateSourceTrigger=PropertyChanged}"
                                                                  Margin="0,0,4,0"/>

                                                    <!-- Edit view (TextBox) and resolved view (pill) overlap; visibility swaps by State. -->
                                                    <Grid Grid.Column="1">
                                                        <TextBox Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                                                 local:TextBoxHelper.Placeholder="Name, alias, or email — Tab to resolve"
                                                                 GotFocus="RecipientBox_GotFocus"
                                                                 LostFocus="RecipientBox_LostFocus"
                                                                 TextChanged="RecipientBox_TextChanged"
                                                                 PreviewKeyDown="RecipientBox_KeyDown">
                                                            <TextBox.Style>
                                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsResolved}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsUnresolved}" Value="True">
                                                                            <Setter Property="BorderBrush" Value="#FFEF4444"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBox.Style>
                                                        </TextBox>
                                                        <Button Click="EditRecipient_Click"
                                                                Visibility="{Binding IsResolved, Converter={StaticResource BoolToVis}}"
                                                                HorizontalContentAlignment="Left"
                                                                ToolTip="{Binding Display}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource RecipientPill}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFromLocal}" Value="True">
                                                                            <Setter Property="Background" Value="#331F5E3F"/>
                                                                            <Setter Property="BorderBrush" Value="#FF22C55E"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsUnverified}" Value="True">
                                                                            <Setter Property="Background" Value="#33F59E0B"/>
                                                                            <Setter Property="BorderBrush" Value="#FFF59E0B"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding PillName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" — " Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Email}" Foreground="{StaticResource Muted}" FontSize="11" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </Grid>

                                                    <!-- Status glyph. The amber "?" state is clickable (opens Add-to-contacts).
                                                         Other states are passive; hit-testing is disabled via IsHitTestVisible. -->
                                                    <Button Grid.Column="2" Margin="6,0" VerticalAlignment="Center"
                                                            Padding="4,0" MinWidth="20" MinHeight="20"
                                                            Click="StatusIcon_Click"
                                                            Background="Transparent" BorderThickness="0"
                                                            FontSize="14" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Setter Property="Content" Value=""/>
                                                                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                                <Setter Property="ToolTip" Value=""/>
                                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsResolving}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Setter Property="Content" Value="⟳"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                                        <Setter Property="ToolTip" Value="Resolving…"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsFromOutlook}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Setter Property="Content" Value="Ⓞ"/>
                                                                        <Setter Property="Foreground" Value="#FF3B82F6"/>
                                                                        <Setter Property="ToolTip" Value="Originally verified via Outlook"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsFromLocal}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Setter Property="Content" Value="●"/>
                                                                        <Setter Property="Foreground" Value="#FF22C55E"/>
                                                                        <Setter Property="ToolTip" Value="Local-only contact (never confirmed by Outlook)"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsUnverified}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Setter Property="Content" Value="?"/>
                                                                        <Setter Property="Foreground" Value="#FFF59E0B"/>
                                                                        <Setter Property="ToolTip" Value="Valid email, but not found in Outlook or the local cache. Click to save to contacts."/>
                                                                        <Setter Property="IsHitTestVisible" Value="True"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsUnresolved}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Setter Property="Content" Value="⚠"/>
                                                                        <Setter Property="Foreground" Value="#FFEF4444"/>
                                                                        <Setter Property="ToolTip" Value="Not a known contact and not a valid email address."/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <Button Grid.Column="3" Content="✕" Style="{StaticResource IconButton}"
                                                            Command="{Binding DataContext.RemoveRecipientCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <!-- ===== Attachments ===== -->
                            <Border Grid.Column="1" Style="{StaticResource InnerCard}" Margin="4,0,0,0"
                                    AllowDrop="True" Drop="Attachments_Drop" DragOver="Attachments_DragOver">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Attachments" Style="{StaticResource SectionTitle}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Browse…" Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.AddAttachmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <Button Content="Folder…" Style="{StaticResource IconButton}"
                                                    ToolTip="Add a folder. Its top-level files are re-scanned every time you send."
                                                    Command="{Binding DataContext.AddAttachmentFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock DockPanel.Dock="Bottom" Margin="0,6,0,0" Style="{StaticResource Hint}"
                                               Text="Drag files or folders here. Folders are re-scanned on every send. Subj / Body inserts the filename."/>

                                    <ListBox ItemsSource="{Binding Attachments}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding DisplayKind}" FontSize="10"
                                                                           Foreground="{StaticResource Muted}" Margin="0,0,6,0"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding ResolvedFileCount, StringFormat={} ({0})}" FontSize="10"
                                                                           Foreground="{StaticResource Muted}" Margin="6,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Path}" FontSize="10"
                                                                       Foreground="{StaticResource Muted}" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="✕" Style="{StaticResource IconButton}"
                                                                Command="{Binding DataContext.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,3,0,2">
                                                        <Button Content="Subj" Style="{StaticResource IconButton}" Margin="0,0,4,0"
                                                                Click="InsertAttachment_Click" Tag="Subject"/>
                                                        <Button Content="Body" Style="{StaticResource IconButton}"
                                                                Click="InsertAttachment_Click" Tag="Body"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <!-- Subject -->
                        <StackPanel Grid.Row="2" Margin="0,0,0,10">
                            <TextBlock Text="Subject" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                                     local:TextBoxHelper.Placeholder="Email subject — supports {{tokens}}"
                                     GotFocus="SubjectBody_GotFocus"
                                     ContextMenu="{StaticResource TokenContextMenu}"
                                     Name="SubjectBox"/>
                        </StackPanel>

                        <!-- Body -->
                        <DockPanel Grid.Row="3">
                            <TextBlock DockPanel.Dock="Top" Text="Body" Style="{StaticResource Label}"/>
                            <TextBox Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MultilineTextBox}"
                                     local:TextBoxHelper.Placeholder="Type your message. Use {{tokens}} from the right panel, or the Subj/Body buttons to insert people and filenames."
                                     GotFocus="SubjectBody_GotFocus"
                                     ContextMenu="{StaticResource TokenContextMenu}"
                                     Name="BodyBox"/>
                        </DockPanel>

                        <!-- Footer -->
                        <Grid Grid.Row="4" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Preview" Style="{StaticResource SubtleButton}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.PreviewCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Button Content="Send all emails" Style="{StaticResource SubtleButton}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.SendAllCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Button Content="Send via Outlook" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding DataContext.SendCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ========== Right: Tokens reference ========== -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Tokens" Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Hint}" Margin="0,0,0,8">
                        <Run Text="Click a token to insert it into the last focused field ("/>
                        <Run x:Name="TokenTargetLabel" Text="Body" FontWeight="SemiBold"/>
                        <Run Text=")."/>
                    </TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Recipients" Style="{StaticResource Label}"/>
                            <WrapPanel Margin="0,0,0,6">
                                <Button Content="{}{{recipients}}"       Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{recipientEmails}}"  Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{recipientCount}}"   Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{greetRecipients}}"  Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{cc}}"               Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{ccEmails}}"         Style="{StaticResource TokenPill}" Click="Token_Click"/>
                            </WrapPanel>

                            <TextBlock Text="Files" Style="{StaticResource Label}"/>
                            <WrapPanel Margin="0,0,0,6">
                                <Button Content="{}{{files}}"            Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{fileList}}"         Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{fileCount}}"        Style="{StaticResource TokenPill}" Click="Token_Click"/>
                            </WrapPanel>

                            <TextBlock Text="Context" Style="{StaticResource Label}"/>
                            <WrapPanel>
                                <Button Content="{}{{sender}}"           Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{email}}"           Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{date}}"             Style="{StaticResource TokenPill}" Click="Token_Click"/>
                                <Button Content="{}{{time}}"             Style="{StaticResource TokenPill}" Click="Token_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Local-cache autocomplete, shown 300ms after user stops typing. -->
            <Popup x:Name="Autocomplete" StaysOpen="True" Placement="Bottom"
                   AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="6" Padding="4" Width="320">
                    <ListBox x:Name="AutocompleteList" MaxHeight="220"
                             BorderThickness="0" Background="Transparent"
                             PreviewMouseLeftButtonUp="AutocompleteList_Click"
                             PreviewKeyDown="AutocompleteList_KeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Email}" Foreground="{StaticResource Muted}" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>

            <!-- Shown when a typed query matches multiple contacts; user picks one. -->
            <Popup x:Name="AmbiguousPicker" StaysOpen="False" Placement="Bottom"
                   AllowsTransparency="True" PopupAnimation="Fade">                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="6" Padding="8" Width="320">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Label}"
                                   Text="Multiple matches — pick one"/>
                        <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Hint}" Margin="0,6,0,0"
                                   Text="Enter picks the highlighted row. Esc cancels."/>
                        <ListBox x:Name="AmbiguousList" MaxHeight="260"
                                 MouseDoubleClick="AmbiguousCommit_Click"
                                 PreviewKeyDown="AmbiguousList_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,2">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Email}" Foreground="{StaticResource Muted}" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Popup>
        </Grid>

    </DockPanel>
</Window>
